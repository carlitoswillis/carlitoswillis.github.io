---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

const secondary = [
  {
    name: 'armak.tech',
    tech: 'Node.js, Express, EJS, Helmet',
    blurb:
      'Live production website for a Southern California low-voltage & networking firm. Every page is driven by a single structured content source, so the client’s content changes never mean touching templates — plus Helmet security headers and dynamic SEO meta.',
    links: [
      { label: 'live site', href: 'https://armak.tech' },
      { label: 'repo', href: 'https://github.com/carlitoswillis/armak.tech' },
    ],
  },
  {
    name: 'Incighder',
    tech: 'TypeScript, React, Node.js, Spotify / YouTube / SoundCloud / TikTok APIs',
    blurb:
      'Artist-scouting tool built around a surprisingly hard question: are these accounts actually the same artist? A local LLM verifies ambiguous profile matches, while patient scraping (24-hour caches, jittered backoff) turns Spotify, YouTube, SoundCloud, TikTok, and Instagram metrics into comparable growth signals.',
    links: [{ label: 'repo', href: 'https://github.com/carlitoswillis/incighder' }],
  },
  {
    name: 'Beatpack',
    tech: 'Electron, React, Node.js, ffmpeg',
    blurb:
      'Started as scripts for my own music workflow, grew into a desktop app that automates the release grind for beat producers: stem zipping, MP3 encoding, cover-art overlay, and ffmpeg-driven video assembly. One drop replaces an afternoon of manual export work.',
    links: [{ label: 'repo', href: 'https://github.com/carlitoswillis/beatpack' }],
  },
  {
    name: 'Expert',
    tech: 'React, Node.js, Express, MySQL, OCR, Docker',
    blurb:
      'Personal-knowledge tool that makes everything you’ve read searchable by content: an OCR ingestion pipeline turns a scattered pile of PDFs into one queryable research collection, with cross-source synthesis as the next arc.',
    links: [{ label: 'repo', href: 'https://github.com/carlitoswillis/expert' }],
  },
  {
    name: 'Ezzy Shop',
    tech: 'AWS EC2, Nginx, Redis, PostgreSQL, Node.js, Express, React, Docker',
    blurb:
      'Chased bottlenecks through the whole stack of an e-commerce product service — application, database schema, and infrastructure — with every change measured under load (K6, Loader.io).',
    metrics: [
      { value: '200 → 800', unit: 'req/s' },
      { value: '230 → 70', unit: 'ms' },
    ],
    links: [],
  },
];
---

<Base
  title="Carlitos Willis — Software Engineer"
  description="Software engineer in Los Angeles. Projects that start with a question worth chasing — event sourcing, reverse-engineered synthesizer firmware, developer tools for music — each with working software, source code, or a technical write-up."
>
  <!-- Hero -->
  <section class="border-b border-line">
    <div class="mx-auto max-w-2xl px-5 pt-16 pb-14 sm:pt-20">
      <p class="font-mono text-sm text-steel">
        <span class="text-signal">$</span> currently: rewinding a task board, indexing a decade
        of Ableton sessions, reverse-engineering a synth
      </p>
      <h1 class="mt-4 font-display text-4xl leading-[1.05] font-bold tracking-tight sm:text-5xl">
        I reverse-engineer synthesizer firmware for fun, and ship production
        systems for a living.
      </h1>
      <p class="mt-5 max-w-xl leading-relaxed text-steel">
        Most of my projects start with a question I can't let go. Lately that's
        led me to event sourcing, reverse-engineering an old synthesizer, and
        building developer tools for my own music workflow. Every project here
        includes working software, source code, or a write-up of how it works.
      </p>
      <p class="mt-4 max-w-xl text-sm text-steel">
        Most recently: full-stack growth engineering at{' '}
        <span class="font-medium text-ink">Gusto</span> — nine A/B tests in six
        months, a <span class="font-mono font-medium text-ink">+15.5%</span> lift
        in conversion.
      </p>
      <div class="mt-6 flex flex-wrap gap-x-5 gap-y-2 text-sm">
        <a href="#projects" class="link">projects</a>
        <a href="/resume/" class="link" target="_blank" rel="noopener noreferrer">resume</a>
        <a href="https://github.com/carlitoswillis" class="link" target="_blank" rel="noopener noreferrer">github</a>
        <a href="https://linkedin.com/in/carlitoswillis" class="link" target="_blank" rel="noopener noreferrer">linkedin</a>
        <a href="mailto:carlitoswillis@berkeley.edu" class="link">email</a>
      </div>
    </div>
  </section>

  <!-- Featured projects -->
  <section id="projects" aria-label="Featured projects">
    {
      projects.map((p) => (
        <article class="border-b border-line">
          <div class="mx-auto max-w-3xl px-5 py-12">
            <p class="text-sm text-steel lowercase">
              {p.data.domain}
              {p.data.live && <span class="dot-live ml-2 inline-block h-1.5 w-1.5 rounded-full bg-signal align-middle" />}
              {' · '}
              {p.data.demo ? (
                <a href={p.data.demo} class="link" target="_blank" rel="noopener noreferrer">
                  {p.data.statusDetail}
                </a>
              ) : (
                p.data.statusDetail
              )}
            </p>
            <h2 class="mt-2 font-display text-3xl font-bold tracking-tight">
              <a href={`/projects/${p.id}/`} class="hover:text-signal">
                {p.data.title}
              </a>
            </h2>
            {p.data.video && (
              <video
                class="mt-5 w-full rounded-md border border-line shadow-[0_1px_2px_rgba(24,24,21,0.04),0_8px_24px_-8px_rgba(24,24,21,0.15)]"
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
                poster={p.data.poster}
                src={p.data.video}
                aria-label={p.data.videoAlt}
              />
            )}
            <p class="mt-5 max-w-xl leading-relaxed text-steel">{p.data.summary}</p>
            <div class="mt-5 flex flex-wrap gap-x-5 gap-y-2 text-sm">
              {p.data.demo && (
                <a href={p.data.demo} class="link" target="_blank" rel="noopener noreferrer">
                  live demo
                </a>
              )}
              <a href={`/projects/${p.id}/`} class="link">
                case study
              </a>
              {p.data.repo && (
                <a href={p.data.repo} class="link" target="_blank" rel="noopener noreferrer">
                  repo
                </a>
              )}
            </div>
          </div>
        </article>
      ))
    }
  </section>

  <!-- Secondary list -->
  <section aria-label="More projects">
    <div class="mx-auto max-w-2xl px-5 py-12">
      <p class="text-steel">Other projects</p>
      <div class="mt-4 divide-y divide-line">
        {
          secondary.map((s) => (
            <div class="py-6 first:pt-0">
              <h3 class="font-display font-medium">{s.name}</h3>
              <p class="mt-1 text-sm text-steel">{s.tech}</p>
              {s.metrics && (
                <div class="mt-2 flex flex-wrap gap-x-5 gap-y-1">
                  {s.metrics.map((m) => (
                    <p class="font-mono text-sm font-medium text-ink">
                      {m.value} <span class="text-steel">{m.unit}</span>
                    </p>
                  ))}
                </div>
              )}
              <p class="mt-2 leading-relaxed text-steel">{s.blurb}</p>
              <div class="mt-3 flex gap-5 text-sm">
                {s.links.length ? (
                  s.links.map((l) => (
                    <a href={l.href} class="link" target="_blank" rel="noopener noreferrer">
                      {l.label}
                    </a>
                  ))
                ) : (
                  <span class="text-steel">write-up on request</span>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Base>
